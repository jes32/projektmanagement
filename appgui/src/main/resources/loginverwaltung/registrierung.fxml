<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="de.pm.loginverwaltng.RegisterController"
            prefHeight="400.0" prefWidth="600.0">


   <children>

      <Label layoutX="170.0" layoutY="40.0" text="REGISTRIERUNG">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
      </Label>

      <Label layoutX="120.0" layoutY="120.0" text="Benutzername" />
      <TextField fx:id="tf_username" layoutX="120.0" layoutY="145.0" prefWidth="250.0" />

      <Label layoutX="120.0" layoutY="190.0" text="Passwort" />
      <PasswordField fx:id="tf_password" layoutX="120.0" layoutY="215.0" prefWidth="250.0" />

      <Label fx:id="lb_error" layoutX="120.0" layoutY="260.0" textFill="red" />

      <Button fx:id= "bt_register" layoutX="120.0" layoutY="300.0" text="Registrieren" onAction="#handleRegister" />

      <Button fx:id= "bt_back" layoutX="240.0" layoutY="300.0" text="Zurück" onAction="#backToLogin" />

   </children>
</AnchorPane>